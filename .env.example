# LINE Messaging API Credentials
# Get from: https://developers.line.biz/console/
LINE_CHANNEL_ID=your_channel_id
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_access_token
LINE_DEFAULT_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database (sqlite or mssql)
LINEAGENT_DB=sqlite

# Optional: MSSQL connection (when LINEAGENT_DB=mssql)
# MSSQL_CONNECTION=Server=.;Database=DB_LineAgent;Trusted_Connection=True;TrustServerCertificate=True
